{
  "name": "claude-ollama",
  "version": "1.0.0",
  "description": "MCP server for integrating Claude with local Ollama models",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-ollama": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsx watch src/index.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "setup_mac": "bash scripts/setup_mac.sh",
    "run_mac": "bash scripts/run_mac.sh",
    "kill_mac": "bash scripts/kill_mac.sh"
  },
  "keywords": [
    "mcp",
    "ollama",
    "ai",
    "local-models",
    "claude"
  ],
  "author": "Alvin Wilta",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}