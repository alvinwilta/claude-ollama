## Copy to `.env` and adjust as needed

# Global default model used when tool calls omit `model`
OLLAMA_DEFAULT_MODEL=gpt-oss

# Optional per-tool defaults (override OLLAMA_DEFAULT_MODEL)
OLLAMA_DEFAULT_MODEL_TEXT=gpt-oss
OLLAMA_DEFAULT_MODEL_CHAT=gpt-oss
OLLAMA_DEFAULT_MODEL_CODE=gpt-oss
OLLAMA_DEFAULT_MODEL_SUMMARISE=gpt-oss

# Embeddings usually require an embedding model; defaults to `nomic-embed-text`
OLLAMA_DEFAULT_MODEL_EMBED=nomic-embed-text

# Optional: override Ollama endpoint and request timeout (ms)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300000
